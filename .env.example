# Telegram Bot
BOT_TOKEN=123456:ABC-DEF...

# GitHub Webhook
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# Server
HOST=0.0.0.0
PORT=8000

# Channel config (use these OR config file)
CHANNEL_CHAT_ID=-1002188528272
CHANNEL_THREAD_ID=31821
CHANNEL_REPOS=hydra-monitors/hm-core,hydra-monitors/*

# Alternative: config file path (if CHANNEL_* not set)
# CONFIG_PATH=config.yaml

# Dedup & Batching
DEDUP_TTL_SECONDS=10
SECURITY_BATCH_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
